# Copiar a .env y completar con tus credenciales MariaDB
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=tu_usuario
DB_PASSWORD=tu_password
DB_NAME=tu_base

# Tabla principal (cabecera + códigos de barras)
TABLE_FACTURAS=facturas

# Histórico m³ para el gráfico (cod_sum = suministro)
TABLE_CONSUMOS=factura_consumo

# Detalle ERP (consultas.py / generar.py)
TABLE_ITEMS_ERP=factura_items_erp
TABLE_CESPAFIP=cespafip

# Tablas legacy (test_db.py / db.py)
TABLE_ITEMS=factura_items
TABLE_DEUDAS=factura_deudas_anteriores

CONSUMO_CHART_MESES=13

# API HTTP (python -m api.main)
API_KEY=dev-secret-local
API_HOST=127.0.0.1
API_PORT=8000
